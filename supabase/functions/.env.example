# SUPABASE SERVICE ROLE (Administrative Access)
# REQUIRED: For user management and password resets via Edge Functions.
# Never expose this key to the frontend!
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# LIVEKIT SECRETS
# REQUIRED: For generating meeting tokens.
LIVEKIT_API_KEY=your_api_key_here
LIVEKIT_API_SECRET=your_api_secret_here
